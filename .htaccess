# ============================================
# ARK TELEMETRY - PROTECTION v3.1.1.0
# ============================================

# Block access to all files by default
<Files "*">
    Require all denied
</Files>

# Allow only essential endpoints
<Files "validate.php">
    Require all granted
</Files>

<Files "collect.php">
    Require all granted
</Files>

<Files "api.php">
    Require all granted
</Files>

<Files "stats.php">
    Require all granted
</Files>

<Files "dashboard.php">
    Require all granted
</Files>

# NAAN cache - cron only (not publicly accessible)
<Files "naan_cache.php">
    Require all denied
</Files>

# Scheduler - cron only (not publicly accessible)
<Files "scheduler.php">
    Require all denied
</Files>

<FilesMatch "\.(css|js)$">
    Require all granted
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "DENY"
</IfModule>